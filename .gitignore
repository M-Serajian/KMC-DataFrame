# ==============================================================================
# KMC-DataFrame .gitignore
# ==============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
.eggs/

# ── C/C++ build artifacts ─────────────────────────────────────────────────────
*.o
*.a
*.lo
*.la

# ── KMC build outputs ─────────────────────────────────────────────────────────
bin/
include/

# ── pip / scikit-build-core ───────────────────────────────────────────────────
_skbuild/
*.whl
wheelhouse/

# ── Compiled Python extension (built artifact, not source) ───────────────────
kmcpy/_core*.so
kmcpy/_core*.pyd

# ── Temp / scratch ────────────────────────────────────────────────────────────
*.tmp
*.temp
kmcpy_*/
build/*

# ── Makefile backup (created by conda_setup.py) ───────────────────────────────
Makefile.original

# ── Testing: compiled binaries and profiling artifacts ───────────────────────
/testing/test_kmc_ram
/testing/strace_out.txt
/testing/strace_raw.txt
/testing/io_profile.sh
/testing/tmp/
/testing/*.kmc_pre
/testing/*.kmc_suf
/testing/wrapper.py
/testing/*

# ── Editors ───────────────────────────────────────────────────────────────────
*~
*.swp
*.swo
.vscode/
.idea/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# ── Windows ───────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp

# ── Visual Studio ─────────────────────────────────────────────────────────────
/.vs/kmc/v17
/.vs/kmc/FileContentIndex
/.vs
/Debug
/kmc_CLI/Debug
/kmc_CLI/x64/Debug/kmc_CLI.tlog
/kmc_CLI/x64/Debug
/kmc_core/Debug
/kmc_core/x64/Debug
/kmc_dump/Debug/kmc_dump.tlog
/kmc_dump/Debug
/kmc_dump/x64/Debug
